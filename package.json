{
  "name": "defender-game",
  "version": "1.0.0",
  "description": "Browser based game",
  "keywords": [
    "game"
  ],
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "coverage": "jest --coverage",
    "preshow:coverage": "npm run coverage",
    "show:coverage": "live-server coverage/lcov-report",
    "preshow:dist": "npm run build",
    "show:dist": "live-server dist"
  },
  "license": "ISC",
  "author": "aleksa",
  "type": "commonjs",
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/jest": "^29.5.5",
    "babel-jest": "^30.3.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.50.0",
    "eslint-plugin-jest": "^27.4.2",
    "html-loader": "^4.2.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "live-server": "^1.2.2",
    "mini-css-extract-plugin": "^2.10.1",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "core-js": "^3.49.0"
  },
  "homepage": "https://github.com/AleksaOsk/clean-fun#readme",
  "bugs": {
    "url": "https://github.com/AleksaOsk/clean-fun/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:AleksaOsk/clean-fun.git"
  },
  "jest": {
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "lines": 100,
        "branches": 100,
        "functions": 100,
        "statements": 100
      }
    }
  }
}
